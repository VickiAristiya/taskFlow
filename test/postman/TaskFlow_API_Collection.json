    {
      "name": "/api/tasks/{id} (Update Task)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code should be 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Title should be updated\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.title).to.include(\"Updated\");\r",
              "});\r",
              "\r",
              "pm.test(\"Status should be updated to 'in-progress'\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.status).to.eql(\"in-progress\");\r",
              "});\r",
              "\r",
              "pm.test(\"Should have updated_at timestamp\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('updated_at');\r",
              "    pm.expect(jsonData.updated_at).to.not.be.null;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"Belajar Automation Testing - Updated\",\r\n    \"description\": \"Sudah mempelajari Postman, Newman, dan Selenium\",\r\n    \"status\": \"in-progress\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/tasks/{{task_id}}",
