  "item": [
    {
      "name": "/api/task (Create Task)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test script untuk Create Task\r",
              "pm.test(\"Status code should be 201 Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response should have correct structure\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('id');\r",
              "    pm.expect(jsonData).to.have.property('title');\r",
              "    pm.expect(jsonData).to.have.property('description');\r",
              "    pm.expect(jsonData).to.have.property('status');\r",
              "    pm.expect(jsonData).to.have.property('created_at');\r",
              "});\r",
              "\r",
              "pm.test(\"Title should match sent data\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.title).to.eql(\"Belajar Automation Testing\");\r",
              "});\r",
              "\r",
              "pm.test(\"Status should be 'pending'\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.status).to.eql(\"pending\");\r",
              "});\r",
              "\r",
              "// Simpan task ID untuk digunakan di request selanjutnya\r",
              "const jsonData = pm.response.json();\r",
              "pm.environment.set(\"task_id\", jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"Belajar Automation Testing\",\r\n    \"description\": \"Mempelajari Postman, Newman, dan Selenium\",\r\n    \"status\": \"pending\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/tasks",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "tasks"
          ]
        }
      },
      "response": []
    },
    {
      "name": "/api/task (Get All Task)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code should be 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response should be an array\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Response time should be less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Array should contain at least one task\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.length).to.be.at.least(1);\r",
              "});\r",
              "\r",
              "pm.test(\"Each task should have required properties\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    jsonData.forEach(task => {\r",
              "        pm.expect(task).to.have.property('id');\r",
              "        pm.expect(task).to.have.property('title');\r",
              "        pm.expect(task).to.have.property('status');\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{base_url}}/api/tasks",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "tasks"
          ]
        }
      },
      "response": []
    },
    {
      "name": "/api/tasks/{id} (Get Single Task)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code should be 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Task ID should match requested ID\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    const requestedId = parseInt(pm.environment.get(\"task_id\"));",
              "    pm.expect(jsonData.id).to.eql(requestedId);",
              "});\r",
              "\r",
              "pm.test(\"Should return correct task properties\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('title');\r",
              "    pm.expect(jsonData).to.have.property('description');\r",
              "    pm.expect(jsonData).to.have.property('status');\r",
              "    pm.expect(jsonData).to.have.property('created_at');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/tasks/{{task_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "tasks",
            "{{task_id}}"
          ]
        }
      },
      "response": []
    },
