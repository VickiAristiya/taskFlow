    {
      "name": "/api/tasks/{id} (Delete Task)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code should be 204 No Content\", function () {\r",
              "    pm.response.to.have.status(204);\r",
              "});\r",
              "\r",
              "// Verifikasi bahwa task benar-benar terhapus\r",
              "pm.test(\"Task should not be retrievable after deletion\", function () {\r",
              "    const taskId = pm.environment.get(\"task_id\");\r",
              "    pm.sendRequest(`${pm.environment.get(\"base_url\")}/api/tasks/${taskId}`, function (err, res) {\r",
              "        pm.expect(res.code).to.eql(404);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/tasks/{{task_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "tasks",
            "{{task_id}}"
          ]
        }
      },
      "response": []
