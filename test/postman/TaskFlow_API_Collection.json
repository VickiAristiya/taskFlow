      "name": "/api/tasks (Validation Test - Missing Required Field)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code should be 422 Unprocessable Entity\", function () {\r",
              "    pm.response.to.have.status(422);\r",
              "});\r",
              "\r",
              "pm.test(\"Error should mention missing 'title' field\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.detail[0].loc).to.include(\"title\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
