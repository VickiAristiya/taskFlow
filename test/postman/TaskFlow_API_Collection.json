              "\r",
              "pm.test(\"Error message should be 'Tugas tidak ditemukan'\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.detail).to.eql(\"Tugas tidak ditemukan\");\r",
              "});"
            ],
            "type": "text/javascript",
